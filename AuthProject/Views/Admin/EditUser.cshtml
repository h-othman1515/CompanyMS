@model AuthProject.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit user";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">

        <div class="d-flex align-items-center gap-2 mb-4">
            <a asp-action="Users" class="btn btn-sm btn-outline-secondary">
                &larr; Back
            </a>
            <h4 class="mb-0">Edit user</h4>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">

                <p class="text-muted small mb-3">@Model.Email</p>

                <form asp-action="EditUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Age" class="form-label"></label>
                        <input asp-for="Age" class="form-control" type="number" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Roles</label>
                        <div class="border rounded p-3">
                            @foreach (var role in Model.AllRoles)
                            {
                                var isChecked = Model.SelectedRoles.Contains(role);
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="SelectedRoles"
                                           value="@role"
                                           id="role_@role"
                                           @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role">
                                        @role
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="form-text">Check all roles this user should have.</div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Save changes</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}